{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["DOM", "ES2020"], // para acessar coisas do navegador (addevent / queryselector// document...)
    "rootDir": "./js", // ok
    "outDir": "./dist", // onde o typescript vai gerar o js
    "strict": true, // deus mim ajude 
    "sourceMap": true,
    "noImplicitAny": true, // tudo com tipo
    "skipLibCheck": true,
    "types": ["jest"]
  },
  "include": ["js/**/*.ts"]
}